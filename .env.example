# ---------------------------------------------------------------------------
# Paxer environment. Copy to .env and fill in. All values are server-side only.
# Never expose these to the client. (Section 13)
# ---------------------------------------------------------------------------

# Database (Vercel Postgres / Neon). DATABASE_URL is used by the app + Drizzle.
# Locally you can point this at any Postgres instance.
DATABASE_URL=postgresql://user:password@localhost:5432/paxer
POSTGRES_URL=postgresql://user:password@localhost:5432/paxer

# Vercel Blob (file uploads for bills / EOBs)
BLOB_READ_WRITE_TOKEN=

# Anthropic API (server-side only; powers ingestion, audit, drafting)
ANTHROPIC_API_KEY=

# Auth.js (NextAuth v5). Generate AUTH_SECRET with: openssl rand -base64 32
AUTH_SECRET=
AUTH_URL=http://localhost:3000

# Resend (magic-link email + deadline reminders). In dev, links are logged to console.
# RESEND_FROM must be an address on a domain VERIFIED in Resend (paxer.app).
# The onboarding@resend.dev sandbox sender only delivers to the Resend account owner.
RESEND_API_KEY=
RESEND_FROM="Paxer <noreply@paxer.app>"

# Cron guard (Section 13). Vercel cron routes require this bearer token.
CRON_SECRET=

# Stripe — Audit API billing (server-side only; never sent PHI). Needs NO BAA
# (no PHI), but DOES need live keys before charging. Billing code is dormant
# until STRIPE_SECRET_KEY + the price IDs are set.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=            # price_… for the $49/mo Pro plan
STRIPE_PRICE_SCALE=          # price_… for the $299/mo Scale plan
STRIPE_PRICE_CONSUMER=       # price_… for the Paxer Plus consumer subscription (gates dispute drafts)
STRIPE_PORTAL_RETURN_URL=    # optional; defaults to AUTH_URL/app/settings
PAXER_CONSUMER_PRICE_LABEL=$12/mo   # display label for the Paxer Plus price
PAXER_FREE_AUDIT_LIMIT=1            # free audits before Paxer Plus is required (first audit free)

# Business config
# Consumer product is free for individuals (0). A future B2B tier could set > 0.
PAXER_FEE_RATE=0
PAXER_DAILY_AI_BUDGET_USD=10
PAXER_FREE_API_QUOTA=100
# Per-user daily AI spend ceiling (cost-abuse protection; one user can't drain
# the global budget). Must be <= PAXER_DAILY_AI_BUDGET_USD to have effect.
PAXER_USER_DAILY_AI_BUDGET_USD=3
